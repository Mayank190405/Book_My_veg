model InventoryLedger {
  id               String                       @id @default(uuid())
  storeId          String
  productId        String
  referenceType    InventoryLedgerReferenceType
  referenceId      String
  quantityChange   Int
  previousQuantity Int
  newQuantity      Int
  createdAt        DateTime                     @default(now())
  createdBy        String

  @@index([storeId])
  @@index([productId])
}



