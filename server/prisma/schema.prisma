generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String                @id @default(uuid())
  phone              String                @unique
  email              String?               @unique
  name               String?
  role               Role                  @default(USER)
  password           String?
  isActive           Boolean               @default(true)
  lastLogin          DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  locationId         String?
  joiningDate        DateTime?
  leavingDate        DateTime?
  profileAddress     String?
  salary             Decimal?              @db.Decimal(10, 2)
  addresses          Address[]
  attendances        Attendance[]
  auditLogs          AuditLog[]
  cart               Cart?
  cashierShifts      CashierShift[]
  khata              CustomerKhata?
  driverAssets       DeliveryAsset[]       @relation("AssetDriver")
  driverAssignments  DriverAssignment[]    @relation("DriverOrders")
  driverCashLedger   DriverCashLedger[]    @relation("DriverCash")
  inventoryLogs      InventoryLog[]
  journalEntries     JournalEntry[]
  mandiRatesCreated  MandiRate[]           @relation("MandiRateStaff")
  mortalityLogsStaff MortalityLog[]        @relation("MortalityStaff")
  packedOrders       Order[]               @relation("OrderPacker")
  orders             Order[]
  periodLocks        PeriodLock[]
  reviews            Review[]
  salaryPayments     SalaryPayment[]
  searchHistory      SearchHistory[]
  staffPerformance   StaffPerformanceLog[] @relation("StaffPerf")
  transfersInitiated StockTransfer[]       @relation("TransferInitiator")
  location           Location?             @relation(fields: [locationId], references: [id])
  supervisorAdjustments CashDrawerAdjustment[] @relation("SupervisorAdjustments")
}

model Address {
  id          String      @id @default(uuid())
  userId      String
  type        AddressType @default(HOME)
  fullAddress String
  landmark    String?
  city        String?
  state       String?
  pincode     String?
  name        String?
  phone       String?
  latitude    Float?
  longitude   Float?
  isDefault   Boolean     @default(false)
  tag         String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  icon      String?
  imageUrl  String?
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
}

model Product {
  id                  String               @id @default(uuid())
  name                String
  slug                String               @unique
  description         String?
  categoryId          String
  images              String[]
  basePrice           Decimal              @db.Decimal(10, 2)
  taxSlab             Decimal              @default(0) @db.Decimal(5, 2)
  weightUnit          WeightUnit           @default(KG)
  minQuantity         Int                  @default(1)
  maxQuantity         Int                  @default(10)
  isActive            Boolean              @default(true)
  countryOfOrigin     String?
  shelfLife           String?
  packagedDate        DateTime?
  fssaiLicense        String?
  nutritionInfo       Json?
  specifications      Json?
  version             Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isWebsitePublished  Boolean              @default(true)
  sku                 String?              @unique
  batch               Batch[]
  cartItems           CartItem[]
  inventory           Inventory[]
  inventoryLogs       InventoryLog[]
  mandiRates          MandiRate[]
  mortalityLogs       MortalityLog[]
  orderItems          OrderItem[]
  pricing             Pricing[]
  category            Category             @relation(fields: [categoryId], references: [id])
  variants            ProductVariant[]
  reviews             Review[]
  sectionProducts     SectionProduct[]
  stockTransfers      StockTransfer[]
  suspendedOrderItems SuspendedOrderItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([createdAt])
}

model ProductVariant {
  id                  String               @id @default(uuid())
  productId           String
  name                String
  price               Decimal              @db.Decimal(10, 2)
  weight              Decimal?             @db.Decimal(10, 2)
  weightUnit          WeightUnit           @default(GM)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  batches             Batch[]
  cartItems           CartItem[]
  inventory           Inventory[]
  inventoryLogs       InventoryLog[]
  mortalityLogs       MortalityLog[]
  orderItems          OrderItem[]
  pricing             Pricing[]
  product             Product              @relation(fields: [productId], references: [id])
  stockTransfers      StockTransfer[]
  suspendedOrderItems SuspendedOrderItem[]

  @@index([productId])
  @@index([isActive])
}

model Location {
  id             String          @id @default(uuid())
  slug           String          @unique
  name           String
  address        String?
  contactNumber  String?
  attendances    Attendance[]
  batches        Batch[]
  cashierShifts  CashierShift[]
  dailySummaries DailySummary[]
  inventory      Inventory[]
  inventoryLogs  InventoryLog[]
  journalEntries JournalEntry[]
  mortalityLogs  MortalityLog[]
  transfersFrom  StockTransfer[] @relation("TransferFrom")
  transfersTo    StockTransfer[] @relation("TransferTo")
  expenses       StoreExpense[]
  users          User[]
}

model Inventory {
  id             String          @id @default(uuid())
  productId      String
  variantId      String?
  locationId     String
  currentStock   Int             @default(0)
  thresholdStock Int             @default(5)
  lastRestocked  DateTime?
  isLowStock     Boolean         @default(false)
  updatedAt      DateTime        @updatedAt
  location       Location        @relation(fields: [locationId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([productId, locationId, variantId])
  @@index([productId])
  @@index([variantId])
}

model Pricing {
  id            String          @id @default(uuid())
  productId     String
  variantId     String?
  channel       Channel         @default(WEB)
  price         Decimal         @db.Decimal(10, 2)
  discountType  DiscountType?
  discountValue Decimal?        @db.Decimal(10, 2)
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean         @default(true)
  updatedAt     DateTime        @updatedAt
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
  @@index([isActive, endDate])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String          @id @default(uuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int             @default(1)
  metadata  Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  cart      Cart            @relation(fields: [cartId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Order {
  id                String               @id @default(uuid())
  userId            String
  totalAmount       Decimal              @db.Decimal(10, 2)
  status            OrderStatus          @default(PENDING)
  paymentStatus     String               @default("PENDING")
  shippingAddress   Json
  deliveryDate      DateTime?
  deliverySlot      String?
  couponId          String?
  discountAmount    Decimal              @default(0) @db.Decimal(10, 2)
  channel           Channel              @default(WEB)
  taxAmount         Decimal              @default(0) @db.Decimal(10, 2)
  isPaid            Boolean              @default(false)
  notes             String?
  shiftId           String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  isCredit          Boolean              @default(false)
  idempotencyKey    String?              @unique
  packedAt          DateTime?
  packerId          String?
  packerNotes       Json?
  verificationPhoto String?
  deliveryOtp       DeliveryOTP?
  driverAssignment  DriverAssignment?
  coupon            Coupon?              @relation(fields: [couponId], references: [id])
  packer            User?                @relation("OrderPacker", fields: [packerId], references: [id])
  shift             CashierShift?        @relation(fields: [shiftId], references: [id])
  user              User                 @relation(fields: [userId], references: [id])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  payments          Payment[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  refunds           Refund[]
}

model OrderItem {
  id               String          @id @default(uuid())
  orderId          String
  productId        String
  variantId        String?
  quantity          Int
  sellingPrice      Decimal         @db.Decimal(10, 2)
  costPriceSnapshot Decimal         @default(0) @db.Decimal(10, 2)
  marginSnapshot    Decimal         @default(0) @db.Decimal(10, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order            Order           @relation(fields: [orderId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
  variant          ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  refundItems      RefundItem[]
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  remark    String?
  changedBy String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String
  amount        Decimal  @db.Decimal(10, 2)
  method        String
  transactionId String?
  status        String
  metadata      Json?
  createdAt     DateTime @default(now())
  changeGiven   Decimal? @db.Decimal(10, 2)
  denominations Json?
  order         Order    @relation(fields: [orderId], references: [id])
}

model SuspendedOrder {
  id             String               @id @default(uuid())
  staffId        String
  customerMobile String?
  customerName   String?
  totalAmount    Decimal              @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  items          SuspendedOrderItem[]

  @@index([staffId])
}

model SuspendedOrderItem {
  id               String          @id @default(uuid())
  suspendedOrderId String
  productId        String
  variantId        String?
  quantity         Int
  price            Decimal         @db.Decimal(10, 2)
  unit             String          @default("pcs")
  product          Product         @relation(fields: [productId], references: [id])
  suspendedOrder   SuspendedOrder  @relation(fields: [suspendedOrderId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id])
}

model CashierShift {
  id              String                 @id @default(uuid())
  userId          String
  startTime       DateTime               @default(now())
  endTime         DateTime?
  status          String                 @default("OPEN")
  openingBalance  Decimal                @default(0) @db.Decimal(10, 2)
  closingBalance  Decimal?               @db.Decimal(10, 2)
  totalSales      Decimal                @default(0) @db.Decimal(10, 2)
  // Media Breakdown
  expectedCash    Decimal                @default(0) @db.Decimal(10, 2)
  expectedOnline  Decimal                @default(0) @db.Decimal(10, 2)
  expectedCredit  Decimal                @default(0) @db.Decimal(10, 2)
  declaredCash    Decimal?               @db.Decimal(10, 2)
  variance        Decimal?               @db.Decimal(10, 2)
  
  locationId      String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  
  location        Location?              @relation(fields: [locationId], references: [id])
  user            User                   @relation(fields: [userId], references: [id])
  orders          Order[]
  refunds         Refund[]
  adjustments     CashDrawerAdjustment[]

  @@index([userId])
  @@index([locationId])
}

model Refund {
  id                String       @id @default(uuid())
  orderId           String
  cashierShiftId    String
  totalAmount       Decimal      @db.Decimal(10, 2)
  reason            String?
  status            RefundStatus @default(COMPLETED)
  idempotencyKey    String?      @unique
  eventId           String       @db.Uuid
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  order             Order        @relation(fields: [orderId], references: [id])
  shift             CashierShift @relation(fields: [cashierShiftId], references: [id])
  items             RefundItem[]

  @@index([orderId])
  @@index([cashierShiftId])
  @@index([eventId])
}

model RefundItem {
  id                      String   @id @default(uuid())
  refundId                String
  orderItemId             String
  quantityRefunded        Int
  amountRefunded          Decimal  @db.Decimal(10, 2)
  originalSellingPriceSnapshot Decimal  @db.Decimal(10, 2)
  originalCostSnapshot    Decimal  @db.Decimal(10, 2)
  isRestocked             Boolean  @default(true)
  
  refund                  Refund    @relation(fields: [refundId], references: [id])
  orderItem               OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([refundId])
}

model CashDrawerAdjustment {
  id                String   @id @default(uuid())
  shiftId           String
  amount            Decimal  @db.Decimal(10, 2)
  type              String // OVERRIDE, CORRECTION
  reason            String
  supervisorId      String
  eventId           String   @db.Uuid
  createdAt         DateTime @default(now())
  
  shift             CashierShift @relation(fields: [shiftId], references: [id])
  supervisor        User         @relation("SupervisorAdjustments", fields: [supervisorId], references: [id])

  @@index([shiftId])
  @@index([eventId])
}

model SecurityAuditLog {
  id                 String   @id @default(uuid())
  tableName          String
  attemptedOperation String
  attemptedBy        String?
  timestamp          DateTime @default(now())
  rawQuerySnippet    String?
  severity           String   @default("CRITICAL")

  @@index([timestamp])
}

model Banner {
  id        String         @id @default(uuid())
  position  BannerPosition @default(HOME_TOP)
  imageUrl  String
  link      String?
  isActive  Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Section {
  id        String           @id @default(uuid())
  title     String
  type      String
  rules     Json?
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  products  SectionProduct[]
}

model SectionProduct {
  id        String  @id @default(uuid())
  sectionId String
  productId String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id])
  section   Section @relation(fields: [sectionId], references: [id])

  @@unique([sectionId, productId])
}

model OtpTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  content   String
  updatedAt DateTime @updatedAt
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  title     String
  body      String
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String
  updatedAt DateTime @updatedAt
}

model Review {
  id                 String   @id @default(uuid())
  userId             String
  productId          String
  rating             Int      @default(5)
  comment            String?
  images             String[]
  isVerifiedPurchase Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  product            Product  @relation(fields: [productId], references: [id])
  user               User     @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
}

model SearchHistory {
  id             String   @id @default(uuid())
  userId         String
  query          String
  count          Int      @default(1)
  lastSearchedAt DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, query])
  @@index([userId])
  @@index([lastSearchedAt])
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  discountType   DiscountType @default(FLAT)
  discountValue  Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal      @default(0) @db.Decimal(10, 2)
  maxDiscount    Decimal?     @db.Decimal(10, 2)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  usageLimit     Int?
  usedCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  orders         Order[]
}

model ChartOfAccount {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  category      AccountCategory
  description   String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  ledgerEntries LedgerEntry[]
}

model JournalEntry {
  id            String         @id @default(uuid())
  date          DateTime       @default(now())
  reference     String?
  description   String?
  transactionId String         @unique
  locationId    String
  staffId       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  inventoryLogs InventoryLog[]
  location      Location       @relation(fields: [locationId], references: [id])
  staff         User?          @relation(fields: [staffId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([locationId])
  @@index([date])
}

model LedgerEntry {
  id          String         @id @default(uuid())
  journalId   String
  accountId   String
  debit       Decimal        @default(0) @db.Decimal(12, 2)
  credit      Decimal        @default(0) @db.Decimal(12, 2)
  locationId  String
  fiscalYear  Int
  fiscalMonth Int
  createdAt   DateTime       @default(now())
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
  journal     JournalEntry   @relation(fields: [journalId], references: [id])

  @@index([journalId])
  @@index([accountId])
  @@index([locationId])
  @@index([fiscalYear, fiscalMonth])
}

model PeriodLock {
  id         String    @id @default(uuid())
  year       Int
  month      Int
  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?
  lockedBy   User?     @relation(fields: [lockedById], references: [id])

  @@unique([year, month])
}

model InventoryLog {
  id         String           @id @default(uuid())
  productId  String
  variantId  String?
  batchId    String?
  locationId String
  type       InventoryLogType
  beforeQty  Decimal          @db.Decimal(12, 3)
  afterQty   Decimal          @db.Decimal(12, 3)
  delta      Decimal          @db.Decimal(12, 3)
  journalId  String?
  staffId    String?
  createdAt  DateTime         @default(now())
  batch      Batch?           @relation(fields: [batchId], references: [id])
  journal    JournalEntry?    @relation(fields: [journalId], references: [id])
  location   Location         @relation(fields: [locationId], references: [id])
  product    Product          @relation(fields: [productId], references: [id])
  staff      User?            @relation(fields: [staffId], references: [id])
  variant    ProductVariant?  @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([createdAt])
}

model Batch {
  id            String          @id @default(uuid())
  productId     String
  variantId     String?
  locationId    String
  batchNumber   String
  costPrice     Decimal         @db.Decimal(12, 2)
  initialQty    Decimal         @db.Decimal(12, 3)
  remainingQty  Decimal         @db.Decimal(12, 3)
  receivedDate  DateTime        @default(now())
  expiryDate    DateTime?
  version       Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  location      Location        @relation(fields: [locationId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  inventoryLogs InventoryLog[]
  mortalityLogs MortalityLog[]

  @@index([productId])
  @@index([locationId])
  @@index([expiryDate])
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  oldValue   Json?
  newValue   Json?
  staffId    String?
  locationId String?
  createdAt  DateTime @default(now())
  staff      User?    @relation(fields: [staffId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model DailySummary {
  id            String   @id @default(uuid())
  date          DateTime @unique
  locationId    String
  totalSales    Decimal  @db.Decimal(12, 2)
  totalCogs     Decimal  @db.Decimal(12, 2)
  totalExpenses Decimal  @db.Decimal(12, 2)
  netProfit     Decimal  @db.Decimal(12, 2)
  taxCollected  Decimal  @db.Decimal(12, 2)
  isImmutable   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  location      Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
}

model MandiRate {
  id        String   @id @default(uuid())
  productId String
  date      DateTime @default(now())
  channel   Channel  @default(POS)
  costPrice Decimal  @db.Decimal(10, 2)
  staffId   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  staff     User?    @relation("MandiRateStaff", fields: [staffId], references: [id])

  @@unique([productId, channel])
  @@index([productId])
  @@index([date])
}

model MortalityLog {
  id         String          @id @default(uuid())
  productId  String
  variantId  String?
  locationId String
  batchId    String?
  quantity   Decimal         @db.Decimal(12, 3)
  reason     MortalityReason
  notes      String?
  staffId    String?
  journalId  String?
  createdAt  DateTime        @default(now())
  batch      Batch?          @relation(fields: [batchId], references: [id])
  location   Location        @relation(fields: [locationId], references: [id])
  product    Product         @relation(fields: [productId], references: [id])
  staff      User?           @relation("MortalityStaff", fields: [staffId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([createdAt])
}

model StockTransfer {
  id             String          @id @default(uuid())
  productId      String
  variantId      String?
  fromLocationId String
  toLocationId   String
  quantity       Decimal         @db.Decimal(12, 3)
  status         TransferStatus  @default(PENDING)
  initiatedById  String?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  fromLocation   Location        @relation("TransferFrom", fields: [fromLocationId], references: [id])
  initiatedBy    User?           @relation("TransferInitiator", fields: [initiatedById], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  toLocation     Location        @relation("TransferTo", fields: [toLocationId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
}

model CustomerKhata {
  id           String             @id @default(uuid())
  userId       String             @unique
  creditLimit  Decimal            @default(0) @db.Decimal(10, 2)
  outstanding  Decimal            @default(0) @db.Decimal(10, 2)
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id])
  transactions KhataTransaction[]
}

model KhataTransaction {
  id        String               @id @default(uuid())
  khataId   String
  type      KhataTransactionType
  amount    Decimal              @db.Decimal(10, 2)
  orderId   String?
  notes     String?
  staffId   String?
  createdAt DateTime             @default(now())
  khata     CustomerKhata        @relation(fields: [khataId], references: [id])

  @@index([khataId])
}

model WeightVerificationLog {
  id             String   @id @default(uuid())
  sessionRef     String
  expectedWeight Decimal  @db.Decimal(10, 3)
  actualWeight   Decimal  @db.Decimal(10, 3)
  variance       Decimal  @db.Decimal(10, 3)
  isPassed       Boolean
  staffId        String?
  createdAt      DateTime @default(now())

  @@index([sessionRef])
}

model DeliveryAsset {
  id           String    @id @default(uuid())
  name         String
  type         AssetType
  assignedTo   String?
  isReturned   Boolean   @default(true)
  lastAssigned DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  driver       User?     @relation("AssetDriver", fields: [assignedTo], references: [id])
}

model DriverCashLedger {
  id        String   @id @default(uuid())
  driverId  String
  date      DateTime @default(now())
  codTotal  Decimal  @db.Decimal(10, 2)
  deposited Decimal  @db.Decimal(10, 2)
  variance  Decimal  @db.Decimal(10, 2)
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())
  driver    User     @relation("DriverCash", fields: [driverId], references: [id])

  @@index([driverId])
  @@index([date])
}

model DeliveryOTP {
  id        String   @id @default(uuid())
  orderId   String   @unique
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model DriverAssignment {
  id          String    @id @default(uuid())
  orderId     String    @unique
  driverId    String
  status      String    @default("ASSIGNED")
  clusterZone String?
  assignedAt  DateTime  @default(now())
  deliveredAt DateTime?
  driver      User      @relation("DriverOrders", fields: [driverId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id])

  @@index([driverId])
  @@index([status])
}

model StaffPerformanceLog {
  id             String   @id @default(uuid())
  staffId        String
  date           DateTime
  ordersPackaged Int      @default(0)
  errorCount     Int      @default(0)
  avgPackTimeMin Decimal  @default(0) @db.Decimal(5, 2)
  createdAt      DateTime @default(now())
  staff          User     @relation("StaffPerf", fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
}

model Attendance {
  id         String    @id @default(uuid())
  userId     String
  locationId String
  checkIn    DateTime  @default(now())
  checkOut   DateTime?
  status     String    @default("PRESENT")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  location   Location  @relation(fields: [locationId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([locationId])
  @@index([checkIn])
}

model SalaryPayment {
  id          String   @id @default(uuid())
  userId      String
  amount      Decimal  @db.Decimal(10, 2)
  periodStart DateTime
  periodEnd   DateTime
  paidAt      DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model StoreExpense {
  id          String          @id @default(uuid())
  locationId  String
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime        @default(now())
  description String?
  referenceId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  location    Location        @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([category])
  @@index([date])
}

